# --- Server ---
NODE_ENV=development
PORT=4000
CORS_ORIGIN=*

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://transitops:transitops@localhost:5432/transitops?schema=public"

# --- Redis (BullMQ notifications + dashboard cache) ---
REDIS_URL="redis://localhost:6379"

# --- JWT ---
JWT_ACCESS_SECRET="change_me_access_secret_min_32_chars"
JWT_REFRESH_SECRET="change_me_refresh_secret_min_32_chars"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Seed defaults (change immediately after first login) ---
SEED_ADMIN_EMAIL=admin@transitops.local
SEED_ADMIN_PASSWORD=Admin@12345

# --- Business rule tuning ---
LICENSE_EXPIRY_WARN_DAYS=14
LICENSE_EXPIRY_CRON="0 7 * * *"
MAINTENANCE_ALERT_CRON="0 */6 * * *"
NOTIFICATION_BATCH_WINDOW_MS=4000
DASHBOARD_CACHE_TTL=45
RATE_LIMIT_PER_MIN=300

# --- Transactions ---
TX_TIMEOUT_MS=10000
TX_MAX_WAIT_MS=5000

# --- Misc ---
LOG_LEVEL=info
LOG_QUERIES=false
RUN_WORKER_IN_PROCESS=true
